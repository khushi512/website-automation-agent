# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Choose provider: groq, openai, or anthropic
LLM_PROVIDER=groq

# API Keys (set the one for your chosen provider)
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...

# Model name (in LiteLLM format)
# Groq: groq/qwen/qwen3.6-27b, groq/llama-3.3-70b-versatile
# OpenAI: gpt-4o, gpt-4o-mini
# Anthropic: anthropic/claude-3-5-sonnet-20241022
MODEL_NAME=groq/qwen/qwen3.6-27b

# Model parameters
MAX_TOKENS=4000
TEMPERATURE=0.7

# =============================================================================
# Browser Configuration
# =============================================================================
HEADLESS=false
SLOW_MO_MS=0
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800
SCREENSHOT_DIR=screenshots

# =============================================================================
# Agent Configuration
# =============================================================================
MAX_AGENT_STEPS=25
MAX_MEMORY_ITEMS=5
SUMMARY_MAX_CHARS=160
MAX_RATE_LIMIT_RETRIES=6
RATE_LIMIT_BACKOFF_SECONDS=25.0

# =============================================================================
# Production Settings
# =============================================================================
# Set to true in production
ENVIRONMENT=development